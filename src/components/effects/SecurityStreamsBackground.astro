---
---

<canvas id="security-streams-canvas" aria-hidden="true"></canvas>

<style>
  #security-streams-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: -1;
    pointer-events: none;
    display: block;
  }
</style>

<script>
  import { SECURITY_STREAM_TOKENS, STREAM_GLYPHS } from '../../data/securityStreams';

  function scheduleInit(fn: () => void) {
    if ('requestIdleCallback' in window) {
      requestIdleCallback(() => fn(), { timeout: 2000 });
    } else {
      window.addEventListener('load', () => setTimeout(fn, 0), { once: true });
    }
  }

  function parseHexRgb(hex: string): { r: number; g: number; b: number } | null {
    const h = hex.replace('#', '');
    if (h.length === 6) {
      return {
        r: parseInt(h.slice(0, 2), 16),
        g: parseInt(h.slice(2, 4), 16),
        b: parseInt(h.slice(4, 6), 16),
      };
    }
    return null;
  }

  function randomItem<T>(arr: readonly T[]): T {
    return arr[Math.floor(Math.random() * arr.length)]!;
  }

  type StreamDrop = {
    col: number;
    y: number;
    vy: number;
    text: string;
    opacity: number;
    size: number;
    layer: 'far' | 'mid' | 'near';
    highlight: boolean;
    phase: number;
  };

  function initStreams() {
    const canvas = document.getElementById('security-streams-canvas') as HTMLCanvasElement | null;
    if (!canvas) return;

    const root = document.documentElement;
    const reduceMotionMq = window.matchMedia('(prefers-reduced-motion: reduce)');
    const reduceMotion = reduceMotionMq.matches;
    const narrow = window.matchMedia('(max-width: 767px)').matches;

    const accentStr = getComputedStyle(root).getPropertyValue('--color-accent').trim();
    const bgStr = getComputedStyle(root).getPropertyValue('--color-bg').trim();
    const accentRgb = parseHexRgb(accentStr) ?? { r: 153, g: 255, b: 204 };
    const bgRgb = parseHexRgb(bgStr) ?? { r: 30, g: 30, b: 30 };

    const ctx = canvas.getContext('2d', { alpha: false });
    if (!ctx) return;

    let dpr = Math.min(window.devicePixelRatio || 1, 2);
    let w = 0;
    let h = 0;
    let raf = 0;
    let drops: StreamDrop[] = [];
    let mouseX = 0.5;
    let mouseY = 0.5;
    let targetParallaxX = 0;
    let targetParallaxY = 0;
    let parallaxX = 0;
    let parallaxY = 0;
    let time = 0;

    const cols = narrow ? 6 : 16;
    const dropsPerCol = narrow ? 2 : 4;

    function pickText(): string {
      if (Math.random() < 0.12) return randomItem(STREAM_GLYPHS);
      return randomItem(SECURITY_STREAM_TOKENS);
    }

    function buildDrops() {
      drops = [];
      for (let c = 0; c < cols; c++) {
        for (let i = 0; i < dropsPerCol; i++) {
          const layerRoll = Math.random();
          const layer: StreamDrop['layer'] =
            layerRoll < 0.45 ? 'far' : layerRoll < 0.82 ? 'mid' : 'near';
          const size =
            layer === 'far' ? 8 + Math.random() * 2 : layer === 'mid' ? 10 + Math.random() * 2.5 : 11 + Math.random() * 3;
          const baseOp =
            layer === 'far' ? 0.06 + Math.random() * 0.1 : layer === 'mid' ? 0.1 + Math.random() * 0.14 : 0.14 + Math.random() * 0.16;
          drops.push({
            col: c,
            y: Math.random() * h,
            vy:
              layer === 'far'
                ? 0.25 + Math.random() * 0.35
                : layer === 'mid'
                  ? 0.45 + Math.random() * 0.55
                  : 0.65 + Math.random() * 0.85,
            text: pickText(),
            opacity: Math.min(baseOp, narrow ? baseOp * 0.75 : baseOp),
            size: narrow ? size * 0.92 : size,
            layer,
            highlight: Math.random() < 0.06,
            phase: Math.random() * Math.PI * 2,
          });
        }
      }
    }

    function resize() {
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      w = window.innerWidth;
      h = window.innerHeight;
      canvas.width = Math.floor(w * dpr);
      canvas.height = Math.floor(h * dpr);
      canvas.style.width = `${w}px`;
      canvas.style.height = `${h}px`;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      if (!reduceMotionMq.matches) {
        buildDrops();
      }
    }

    function onMouse(ev: MouseEvent) {
      if (w <= 0) return;
      mouseX = ev.clientX / w;
      mouseY = ev.clientY / h;
      targetParallaxX = (mouseX - 0.5) * (narrow ? 10 : 18);
      targetParallaxY = (mouseY - 0.5) * (narrow ? 6 : 10);
    }

    function drawStaticAmbient() {
      ctx.fillStyle = `rgb(${bgRgb.r},${bgRgb.g},${bgRgb.b})`;
      ctx.fillRect(0, 0, w, h);
      ctx.globalAlpha = 0.035;
      ctx.strokeStyle = `rgb(${accentRgb.r},${accentRgb.g},${accentRgb.b})`;
      ctx.lineWidth = 1;
      const step = narrow ? 120 : 72;
      for (let x = 0; x < w; x += step) {
        ctx.beginPath();
        ctx.moveTo(x + 0.5, 0);
        ctx.lineTo(x + 0.5, h);
        ctx.stroke();
      }
      ctx.globalAlpha = 1;
    }

    function frame() {
      raf = requestAnimationFrame(frame);
      time += 1;

      parallaxX += (targetParallaxX - parallaxX) * 0.04;
      parallaxY += (targetParallaxY - parallaxY) * 0.04;

      ctx.fillStyle = `rgb(${bgRgb.r},${bgRgb.g},${bgRgb.b})`;
      ctx.fillRect(0, 0, w, h);

      const colW = w / cols;

      for (const d of drops) {
        d.y += d.vy;
        const colCenter = (d.col + 0.5) * colW;
        const sway = Math.sin(time * 0.012 + d.phase + d.col * 0.4) * (narrow ? 1.5 : 2.5);
        const x = colCenter + sway + parallaxX * (d.layer === 'near' ? 1.2 : d.layer === 'mid' ? 0.7 : 0.35);

        if (d.y > h + 40) {
          d.y = -30 - Math.random() * h * 0.3;
          d.text = pickText();
          d.highlight = Math.random() < 0.06;
        }

        let op = d.opacity;
        if (d.highlight) op = Math.min(0.42, op * 2.2);

        ctx.font = `${d.size}px "JetBrains Mono", ui-monospace, monospace`;
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';

        if (d.highlight) {
          ctx.shadowColor = `rgba(${accentRgb.r},${accentRgb.g},${accentRgb.b},0.35)`;
          ctx.shadowBlur = narrow ? 4 : 8;
        } else {
          ctx.shadowBlur = 0;
        }

        ctx.fillStyle = `rgba(${accentRgb.r},${accentRgb.g},${accentRgb.b},${op})`;
        ctx.fillText(d.text, x, d.y);
        ctx.shadowBlur = 0;
      }

      ctx.globalAlpha = 1;
    }

    function onResizeOrMotion() {
      resize();
      if (reduceMotionMq.matches) {
        drawStaticAmbient();
      }
    }

    onResizeOrMotion();
    window.addEventListener('resize', onResizeOrMotion);
    window.addEventListener('mousemove', onMouse, { passive: true });

    if (!reduceMotion) {
      frame();
    }

    function teardown() {
      cancelAnimationFrame(raf);
      window.removeEventListener('resize', onResizeOrMotion);
      window.removeEventListener('mousemove', onMouse);
    }
    document.addEventListener('astro:before-preparation', teardown, { once: true });
  }

  scheduleInit(initStreams);
</script>
