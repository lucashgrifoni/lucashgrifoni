---
import type { Project } from '../../data/projects';
import { withBase } from '../../utils/withBase';

interface Props {
  project: Project;
}

const { project } = Astro.props;
const logoUrl = withBase(project.logoSrc);
const statusLabel = project.status.replace(/-/g, ' ');

const statusKind =
  project.status === 'in-development' ? 'muted' : 'live';
---

<div class="project-card-outer" data-tilt-card>
  <article
    class="project-card-inner group relative overflow-hidden rounded-2xl border border-[color-mix(in_srgb,var(--color-accent)_12%,var(--color-border))] bg-gradient-to-b from-[color-mix(in_srgb,var(--color-surface)_95%,transparent)] to-surface p-7 shadow-float transition-[box-shadow,transform] duration-300 ease-out md:p-10 lg:p-12"
    data-project-id={project.id}
  >
    <!-- Brilho radial superior -->
    <div
      class="pointer-events-none absolute -right-20 -top-24 h-64 w-64 rounded-full opacity-40 blur-3xl"
      style="background: radial-gradient(circle, color-mix(in srgb, var(--color-accent) 28%, transparent) 0%, transparent 70%);"
      aria-hidden="true"
    >
    </div>
    <div
      class="pointer-events-none absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-[color-mix(in_srgb,var(--color-accent)_45%,transparent)] to-transparent opacity-80"
      aria-hidden="true"
    >
    </div>

    <div class="relative flex flex-wrap items-center gap-5 md:gap-6">
      <div class="project-logo-frame shrink-0">
        <div class="project-logo-inner">
          <img
            src={logoUrl}
            alt=""
            width="1024"
            height="1024"
            class="project-logo-img"
            loading="lazy"
            decoding="async"
          />
        </div>
      </div>
      <div class="min-w-0 flex-1">
        <div class="flex flex-wrap items-center gap-3 md:gap-4">
          <h2
            class="text-[1.35rem] font-bold leading-tight tracking-tight text-text-primary md:text-[1.65rem]"
          >
            {project.name}
          </h2>
          <span
            class:list={[
              'mono inline-flex items-center rounded-full px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.14em] ring-1',
              statusKind === 'live'
                ? 'text-accent ring-[color-mix(in_srgb,var(--color-accent)_55%,transparent)] bg-[color-mix(in_srgb,var(--color-accent)_10%,transparent)]'
                : 'text-text-muted ring-border-custom bg-[color-mix(in_srgb,var(--color-muted)_12%,transparent)]',
            ]}
          >
            {statusLabel}
          </span>
        </div>
        <p
          class="mt-3 max-w-[40rem] text-[15px] leading-relaxed text-text-muted md:text-base md:leading-relaxed"
        >
          {project.tagline}
        </p>
      </div>
    </div>

    <div
      class="my-8 h-px w-full bg-gradient-to-r from-transparent via-border-custom to-transparent md:my-10"
    >
    </div>

    <div class="relative grid gap-10 md:grid-cols-2 md:gap-14">
      <div class="space-y-4">
        <h3
          class="mono text-[11px] font-semibold uppercase tracking-[0.2em] text-accent/95 md:text-xs"
        >
          What it is
        </h3>
        <div class="space-y-4 text-[15px] leading-[1.75] text-text-primary/95 md:text-[15.5px]">
          {project.what.map((p) => <p>{p}</p>)}
        </div>
      </div>
      <div class="space-y-4">
        <h3
          class="mono text-[11px] font-semibold uppercase tracking-[0.2em] text-accent/95 md:text-xs"
        >
          Why I built it
        </h3>
        <div class="space-y-4 text-[15px] leading-[1.75] text-text-primary/95 md:text-[15.5px]">
          {project.why.map((p) => <p>{p}</p>)}
        </div>
      </div>
    </div>

    <div class="mt-10 md:mt-12">
      <h3
        class="mono mb-5 text-[11px] font-semibold uppercase tracking-[0.2em] text-accent/95 md:text-xs"
      >
        Problems it solves
      </h3>
      <ul class="grid gap-3 sm:gap-3.5">
        {
          project.problems.map((item) => (
            <li class="flex gap-3 text-[15px] leading-snug text-text-primary/95">
              <span
                class="mt-2 h-1.5 w-1.5 shrink-0 rounded-[1px] bg-accent shadow-[0_0_12px_color-mix(in_srgb,var(--color-accent)_55%,transparent)]"
                aria-hidden="true"
              />
              <span>{item}</span>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="mt-9 flex flex-wrap gap-2 md:mt-10">
      {
        project.stack.map((tech) => (
          <span class="mono rounded-md border border-[color-mix(in_srgb,var(--color-accent)_10%,var(--color-border))] bg-[color-mix(in_srgb,var(--color-bg)_55%,transparent)] px-2.5 py-1.5 text-[11px] text-text-muted transition-colors group-hover:border-[color-mix(in_srgb,var(--color-accent)_22%,var(--color-border))] md:text-xs">
            {tech}
          </span>
        ))
      }
    </div>

    <div class="mt-10 flex flex-col gap-3 sm:flex-row sm:items-center sm:gap-4 md:mt-12">
      <a
        class="btn-primary inline-flex justify-center sm:justify-start"
        href={project.repoUrl}
        target="_blank"
        rel="noopener noreferrer"
      >
        View Repository
      </a>
      {
        project.docsUrl ? (
          <a
            class="btn-secondary inline-flex justify-center sm:justify-start"
            href={project.docsUrl}
            target="_blank"
            rel="noopener noreferrer"
          >
            Documentation
          </a>
        ) : null
      }
    </div>
  </article>
</div>

<style>
  /*
   * Logos 1024×1024 (1:1): container maior, padding mais apertado para a arte
   * ocupar melhor a moldura; object-fit: contain sem crop nem distorção.
   */
  .project-logo-frame {
    --logo-frame-size: 5.35rem;
    --logo-frame-pad: 0.45rem;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    overflow: hidden;
    width: var(--logo-frame-size);
    height: var(--logo-frame-size);
    padding: var(--logo-frame-pad);
    border-radius: 1rem;
    border: 1px solid color-mix(in srgb, var(--color-accent) 28%, var(--color-border));
    background: linear-gradient(
      165deg,
      color-mix(in srgb, var(--color-surface) 94%, var(--color-accent)) 0%,
      color-mix(in srgb, var(--color-bg) 92%, transparent) 100%
    );
    box-shadow:
      inset 0 1px 0 color-mix(in srgb, var(--color-accent) 16%, transparent),
      inset 0 -2px 4px rgba(0, 0, 0, 0.35),
      0 6px 20px rgba(0, 0, 0, 0.42),
      0 0 0 1px color-mix(in srgb, var(--color-accent) 9%, transparent),
      0 0 32px color-mix(in srgb, var(--color-accent) 11%, transparent);
  }

  .project-logo-frame::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    background: linear-gradient(
      145deg,
      color-mix(in srgb, var(--color-accent) 8%, transparent) 0%,
      transparent 42%
    );
  }

  /* Canvas quadrado 1:1 — mesma área útil para todas as artes */
  .project-logo-inner {
    position: relative;
    z-index: 1;
    box-sizing: border-box;
    width: 100%;
    height: 100%;
    min-width: 0;
    min-height: 0;
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.5rem;
    background: radial-gradient(
      70% 70% at 50% 50%,
      color-mix(in srgb, var(--color-bg) 28%, transparent) 0%,
      transparent 78%
    );
  }

  .project-logo-img {
    display: block;
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    object-position: center;
    opacity: 1;
    filter: drop-shadow(0 1px 3px rgba(0, 0, 0, 0.45));
  }

  @media (min-width: 768px) {
    .project-logo-frame {
      --logo-frame-size: 6rem;
      --logo-frame-pad: 0.5rem;
      border-radius: 1.125rem;
    }

    .project-logo-inner {
      border-radius: 0.625rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .project-logo-frame {
      box-shadow:
        inset 0 1px 0 color-mix(in srgb, var(--color-accent) 12%, transparent),
        inset 0 -2px 4px rgba(0, 0, 0, 0.3),
        0 4px 14px rgba(0, 0, 0, 0.38),
        0 0 0 1px color-mix(in srgb, var(--color-accent) 8%, transparent);
    }
  }

  @media (hover: hover) and (pointer: fine) {
    .project-card-outer:hover .project-card-inner {
      box-shadow:
        var(--shadow-lg),
        0 0 0 1px color-mix(in srgb, var(--color-accent) 14%, transparent),
        0 0 48px color-mix(in srgb, var(--color-accent) 10%, transparent);
    }

    .project-card-outer:hover .project-logo-frame {
      border-color: color-mix(in srgb, var(--color-accent) 38%, var(--color-border));
      box-shadow:
        inset 0 1px 0 color-mix(in srgb, var(--color-accent) 20%, transparent),
        inset 0 -2px 4px rgba(0, 0, 0, 0.35),
        0 8px 24px rgba(0, 0, 0, 0.45),
        0 0 0 1px color-mix(in srgb, var(--color-accent) 14%, transparent),
        0 0 40px color-mix(in srgb, var(--color-accent) 14%, transparent);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .project-card-outer:hover .project-card-inner {
      box-shadow: var(--shadow-float);
    }
  }
</style>
